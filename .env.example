# Database (required for API routes + Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/launchramp?schema=public"
# Prisma Postgres (hosted): use the connection string from the dashboard — usually ends with
# `/postgres` not `/launchramp`. Put it in `.env.local` to override the line above for seeds.
# Vercel Postgres: if you only see POSTGRES_PRISMA_URL, paste it as DATABASE_URL or rely on
# the app fallback to POSTGRES_PRISMA_URL / POSTGRES_URL. For Vercel builds, expose
# POSTGRES_URL_NON_POOLING (or DATABASE_URL) under Environment Variables → Build, not only Production.

# Twilio (SMS/MMS)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_MESSAGING_SERVICE_SID=your_messaging_service_sid

# Number that receives inbound SMS (must match Twilio "To" / your purchased number), E.164
# TWILIO_INBOUND_NUMBER=+18077818017

# Public origin Twilio used when signing webhooks (no trailing slash), if it differs from request URL
TWILIO_WEBHOOK_BASE_URL=https://launchramp.app

# For webhook default org when no routing (optional)
TWILIO_DEFAULT_ORG_ID=org_launchramp_demo

# Next.js (optional - for server-side fetch in layout)
# Local: http://localhost:3000 — Production: https://launchramp.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ORG_ID=
NEXT_PUBLIC_USER_ID=

# Microsoft Graph (optional — Microsoft 365 search tab)
# Azure AD app registration: client credentials (application permissions + admin consent).
# Typical permissions: Search.Read.All, Mail.Read, Calendars.Read, Files.Read.All (application).
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
