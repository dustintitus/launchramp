{
  "name": "launchramp",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:generate": "turbo run db:generate --filter=@launchramp/db",
    "db:migrate": "turbo run db:migrate --filter=@launchramp/db",
    "db:seed": "turbo run db:seed --filter=@launchramp/db"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  },
  "packageManager": "npm@10.2.0"
}
