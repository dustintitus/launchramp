{
  "name": "launchramp",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "prisma": {
    "seed": "tsx packages/db/prisma/seed.ts"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "vercel:build-web": "bash scripts/vercel-build.sh",
    "lint": "turbo run lint",
    "db:generate": "turbo run db:generate --filter=@launchramp/db",
    "db:migrate": "turbo run db:migrate --filter=@launchramp/db",
    "db:seed": "prisma db seed --schema=packages/db/prisma/schema.prisma"
  },
  "devDependencies": {
    "dotenv": "^16.4.5",
    "prisma": "^5.22.0",
    "tsx": "^4.19.0",
    "turbo": "^2.0.0"
  },
  "packageManager": "npm@10.2.0",
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@next-auth/prisma-adapter": "^1.0.7",
    "next-auth": "^4.24.14"
  }
}
