// LaunchRamp - Kenect-style shared inbox with CRM
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ChannelType {
  sms
  mms
  rcs
  apple_mfb
}

enum MessageDirection {
  inbound
  outbound
}

enum MessageStatus {
  queued
  sent
  delivered
  failed
}

enum LifecycleStage {
  lead
  qualified
  customer
  churned
}

enum ActivityType {
  message_sent
  message_received
  note_added
  stage_changed
  owner_changed
  tag_added
  tag_removed
}

enum ConsentType {
  opt_in
  opt_out
}

enum BookingStatus {
  PENDING
  READY
  COMPLETE
}

enum StaffMemberStatus {
  NA
  PICK_UP
  AVAILABLE
  ON_JOB
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           User[]
  contacts        Contact[]
  conversations   Conversation[]
  channelAccounts ChannelAccount[]
  templates       Template[]
  activities      Activity[]
  bookings        Booking[]
  staffMembers    StaffMember[]
}

model Booking {
  id             String         @id @default(cuid())
  organizationId String
  orderNumber    String
  service        String
  scheduledAt    DateTime
  status         BookingStatus  @default(PENDING)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, orderNumber])
  @@index([organizationId])
  @@index([organizationId, scheduledAt])
}

model StaffMember {
  id             String            @id @default(cuid())
  organizationId String
  name           String
  role           String            @default("Driver")
  license        String?
  availability   Int?
  status         StaffMemberStatus @default(NA)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([organizationId])
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedContacts Contact[] @relation("ContactOwner")
  assignedConversations Conversation[] @relation("ConversationAssignee")
}

model Contact {
  id             String   @id @default(cuid())
  organizationId String
  phone          String
  name           String?
  email          String?
  stage          LifecycleStage @default(lead)
  ownerId        String?
  tags           String[] @default([])
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner          User?           @relation("ContactOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  conversations  Conversation[]
  activities     Activity[]
  consentEvents  ConsentEvent[]

  @@unique([organizationId, phone])
  @@index([organizationId])
  @@index([organizationId, stage])
}

model Conversation {
  id                 String   @id @default(cuid())
  organizationId     String
  contactId          String
  channelAccountId   String
  channelType       ChannelType
  assignedToId       String?
  isUnread          Boolean  @default(true)
  lastMessageAt     DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact        Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)
  channelAccount ChannelAccount @relation(fields: [channelAccountId], references: [id], onDelete: Cascade)
  assignedTo     User?         @relation("ConversationAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  messages       Message[]

  @@unique([organizationId, contactId, channelAccountId])
  @@index([organizationId])
  @@index([organizationId, assignedToId])
  @@index([lastMessageAt])
}

model Message {
  id                 String   @id @default(cuid())
  conversationId     String
  body               String
  direction          MessageDirection
  channelType        ChannelType
  status             MessageStatus @default(queued)
  /// Twilio MessageSid (or other provider id)
  providerMessageId  String?
  mediaUrls          String[] @default([])
  metadata           Json?
  createdAt          DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([providerMessageId])
}

model Activity {
  id             String       @id @default(cuid())
  organizationId String
  contactId      String
  type          ActivityType
  messageId     String?
  metadata      Json?
  createdAt     DateTime     @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact      Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([organizationId, contactId])
  @@index([createdAt])
}

model ChannelAccount {
  id             String   @id @default(cuid())
  organizationId String
  channelType    ChannelType
  phoneNumber   String?
  externalId    String?
  config        Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversations  Conversation[]

  @@index([organizationId])
}

model Template {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  body           String
  variables      String[] @default([])
  createdAt      DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model ConsentEvent {
  id             String     @id @default(cuid())
  contactId      String
  type          ConsentType
  channelType   ChannelType
  source        String?
  metadata      Json?
  createdAt     DateTime   @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
}
