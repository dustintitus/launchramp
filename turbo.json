{
  "$schema": "https://turbo.build/schema.json",
  "envMode": "loose",
  "globalPassThroughEnv": [
    "DATABASE_URL",
    "POSTGRES_PRISMA_URL",
    "POSTGRES_URL",
    "POSTGRES_URL_NON_POOLING",
    "VERCEL",
    "VERCEL_ENV",
    "SKIP_PRISMA_MIGRATE",
    "PRISMA_VERCEL_SYNC",
    "PRISMA_BASELINE_ON_P3005",
    "PRISMA_NO_AUTO_SYNC_P3005",
    "PRISMA_DATABASE_URL",
    "RUN_VERCEL_MIGRATE_SCRIPT",
    "PRISMA_FAIL_OPEN_MIGRATE",
    "PRISMA_DB_PUSH_NO_ACCEPT_DATA_LOSS",
    "BOOTSTRAP_ADMIN_EMAILS"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:seed": {
      "cache": false
    }
  }
}
